# WorldSeed uses LiteLLM — any supported provider works.
# Copy this file to .env and set your API key.
#
# Only ONE provider key is needed. Uncomment the one you use:

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AI...

# See all providers: https://docs.litellm.ai/docs/providers

# Optional: default DM model (shown in lobby, used by CLI)
# Format: model name as listed in the lobby dropdown
# WORLDSEED_DM_MODEL=

# Optional: FLUX image generation (for scene-assets skill)
# BFL_API_KEY=bfl_...
